page {
  background: #f4f6f9;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  padding: 24rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #d9dee8;
  border-radius: 16rpx;
  padding: 22rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.muted {
  color: #657083;
  font-size: 24rpx;
}

.input {
  min-height: 76rpx;
  border: 1rpx solid #d9dee8;
  border-radius: 12rpx;
  background: #fbfcfe;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.button {
  min-height: 76rpx;
  border-radius: 12rpx;
  background: #1f6feb;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
}

.row {
  display: flex;
  align-items: center;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 10rpx;
  background: #dbe1ea;
  margin-right: 16rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #d9dee8;
  border-radius: 14rpx;
  padding: 18rpx;
  margin-bottom: 14rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 800;
}

.sub {
  color: #657083;
  font-size: 23rpx;
  margin-top: 4rpx;
}

.badge {
  display: inline-flex;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #eaf2ff;
  color: #1f6feb;
  font-weight: 800;
  font-size: 22rpx;
}
