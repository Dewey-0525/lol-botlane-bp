<view class="page">
  <view class="title">BP 推荐</view>

  <view class="panel">
    <picker mode="selector" range="{{roles}}" range-key="label" bindchange="onRoleChange">
      <view class="input">推荐位置：{{roleLabel}}</view>
    </picker>
    <input class="input mt" placeholder="己方 ADC" value="{{allyAdText}}" bindinput="onInput" data-key="ally_ad" />
    <input class="input mt" placeholder="己方辅助" value="{{allySupText}}" bindinput="onInput" data-key="ally_sup" />
    <input class="input mt" placeholder="敌方 ADC" value="{{enemyAdText}}" bindinput="onInput" data-key="enemy_ad" />
    <input class="input mt" placeholder="敌方辅助" value="{{enemySupText}}" bindinput="onInput" data-key="enemy_sup" />
    <view class="button mt" bindtap="submit">重新推荐</view>
  </view>

  <view class="panel">
    <view class="name">{{stateInfo.label || '-'}}</view>
    <view class="sub">{{stateInfo.description || '等待推荐'}}</view>
  </view>

  <block wx:for="{{results}}" wx:key="name">
    <view class="card">
      <view class="row">
        <image class="avatar" src="{{apiBase}}{{item.avatar}}" mode="aspectFill" />
        <view>
          <view class="name">{{index + 1}}. {{item.display_name}}</view>
          <view class="sub">{{item.english_name}} · 可信度{{item.confidence_label}}</view>
        </view>
        <view class="badge">{{item.tier}}</view>
      </view>
      <view class="sub">推荐指数 {{item.display_winrate}} · 基础表现 {{item.base_rating || '-'}} · 配合 {{item.synergy_bonus || '-'}} · 对位 {{item.counter_bonus || '-'}}</view>
      <view class="sub">{{item.explanation}}</view>
    </view>
  </block>
</view>
